# ===================== Database =====================
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ===================== Auth (JWT) =====================
JWT_ACCESS_SECRET="your-access-secret-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ===================== Telegram bot (to'lov eslatmalari) =====================
# @BotFather dan olingan token. Faqat shu bot bilan ishlaymiz (guruh shart emas).
TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrsTUVwxyz"

# Webhook sozlashda ixtiyoriy xavfsizlik kaliti (setWebhook secret_token)
TELEGRAM_WEBHOOK_SECRET=""

# Vercel cron: kunlik avtomatik eslatma (/api/cron/payment-reminders)
CRON_SECRET="your-cron-secret-min-16-chars"

# ===================== App =====================
NEXT_PUBLIC_API_URL=""
NEXT_PUBLIC_APP_URL="https://www.arendaai.uz"

# Bir martalik DB init (ixtiyoriy)
SETUP_SECRET=""

# OpenAI (AI agent — keyinroq)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Vercel Blob (rasm yuklash)
BLOB_READ_WRITE_TOKEN=""
