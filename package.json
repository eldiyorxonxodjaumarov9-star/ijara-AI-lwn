{
  "name": "arendahub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate --schema=server/prisma/schema.prisma && next build",
    "vercel-build": "prisma generate --schema=server/prisma/schema.prisma && prisma db push --schema=server/prisma/schema.prisma --skip-generate --accept-data-loss && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate --schema=server/prisma/schema.prisma",
    "db:push": "node scripts/prisma-env.mjs db push --schema=server/prisma/schema.prisma",
    "db:seed": "npm run prisma:seed --prefix server"
  },
  "prisma": {
    "schema": "server/prisma/schema.prisma"
  },
