# ===== Database =====
DATABASE_URL="postgresql://arendahub:arendahub@localhost:5432/arendahub?schema=public"

# ===== App =====
NODE_ENV=development
PORT=4000
API_PREFIX=api
CORS_ORIGIN=http://localhost:3000

# ===== JWT =====
JWT_ACCESS_SECRET=super-secret-access-change-me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=super-secret-refresh-change-me
JWT_REFRESH_EXPIRES=7d

# ===== Security =====
THROTTLE_TTL=60
THROTTLE_LIMIT=120
BCRYPT_SALT_ROUNDS=10

# ===== Uploads =====
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ===== Seed (super admin) =====
SEED_ADMIN_EMAIL=superadmin@arendahub.uz
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=Super Admin
