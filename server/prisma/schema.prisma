// ArendaHub — Enterprise Property Management SaaS
// Prisma schema (PostgreSQL)

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== ENUMS =====================

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
}

enum PropertyStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  RESERVED
}

enum ContractStatus {
  PENDING
  ACTIVE
  EXPIRED
  TERMINATED
}

enum PaymentMethod {
  CASH
  CARD
  BANK
}

enum ExpenseCategory {
  UTILITIES
  SALARY
  TAX
  REPAIR
  MARKETING
  OTHER
}

enum MaintenanceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  CONTRACT_EXPIRED
  LATE_PAYMENT
}

enum ClientStatus {
  NEW
  MATCHED
}

// ===================== MODELS =====================

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  fullName         String
  phone            String?
  role             Role      @default(EMPLOYEE)
  isActive         Boolean   @default(true)
  avatarUrl        String?
  language         String    @default("uz")
  refreshTokenHash String?
  resetToken       String?
  resetTokenExp    DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  notifications Notification[]
  auditLogs     AuditLog[]

  @@index([role])
  @@map("users")
}

model Company {
  id        String   @id @default(uuid())
  name      String   @default("ArendaHub")
  email     String?
  phone     String?
  address   String?
  logoUrl   String?
  currency  String   @default("UZS")
  locale    String   @default("uz")
  timezone  String   @default("Asia/Tashkent")
  taxRate   Float    @default(0.04)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("company")
}

model Property {
  id          String         @id @default(uuid())
  title       String
  address     String
  region      String
  district    String
  building    String?
  rentPrice   Float          @default(0)
  rooms       Int            @default(0)
  area        Float          @default(0)
  description String?
  status      PropertyStatus @default(AVAILABLE)
  images      String[]       @default([])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  contracts    Contract[]
  maintenances Maintenance[]

  @@index([status])
  @@index([region])
  @@index([building])
  @@map("properties")
}

model Tenant {
  id               String   @id @default(uuid())
  fullName         String
  phone            String
  passport         String
  login            String?  @unique
  password         String?
  telegram         String?
  telegramChatId   String?  @unique
  email            String?
  address          String?
  rentAmount       Float    @default(0)
  contractDuration Int?
  entryDate        DateTime?
  paymentDueDate   DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  contracts Contract[]
  clients   Client[]

  @@map("tenants")
}

model Contract {
  id          String         @id @default(uuid())
  propertyId  String
  tenantId    String
  startDate   DateTime
  endDate     DateTime
  monthlyRent Float          @default(0)
  deposit     Float          @default(0)
  status      ContractStatus @default(ACTIVE)
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  property Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([status])
  @@index([propertyId])
  @@index([tenantId])
  @@map("contracts")
}

model Payment {
  id            String        @id @default(uuid())
  contractId    String
  amount        Float
  paymentDate   DateTime      @default(now())
  paymentMethod PaymentMethod @default(CASH)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([paymentDate])
  @@map("payments")
}

model Expense {
  id        String          @id @default(uuid())
  title     String
  amount    Float
  category  ExpenseCategory @default(OTHER)
  date      DateTime        @default(now())
  notes     String?
  receiptUrl String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([category])
  @@index([date])
  @@map("expenses")
}

model Maintenance {
  id          String            @id @default(uuid())
  propertyId  String
  title       String
  description String?
  cost        Float             @default(0)
  status      MaintenanceStatus @default(PENDING)
  images      String[]          @default([])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([propertyId])
  @@map("maintenance")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String?
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  meta      Json?
  createdAt DateTime         @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  meta      Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity])
  @@map("audit_logs")
}

model Client {
  id          String       @id @default(uuid())
  fullName    String
  phone       String
  status      ClientStatus @default(NEW)
  tenantId    String?
  loginCount  Int          @default(1)
  firstLoginAt DateTime     @default(now())
  lastLoginAt  DateTime     @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([phone])
  @@index([status])
  @@index([tenantId])
  @@map("clients")
}
